# === Which backend the admin talks to (Vite, baked at BUILD time) ===
#
# ⚠️ Орчин бүр ӨӨРИЙН датабэйстэй. Энд оруулсан дата нь зөвхөн тухайн backend-ийн
#    DB-д очно — local ба prod-ийн дата ХУВААЛЦАГДДАГГҮЙ / автоматаар синк болдоггүй.
#    .env өөрчилсний дараа admin-аа ДАХИН асаа (npm run dev) — Vite build-time уншина.
#
#  • LOCAL / TEST — өөрийн Mac дээрх backend + local Postgres (test дата).
#       admin-аас оруулсан хичээл/үг = local DB-д (туршихад).
VITE_API_URL=http://localhost:3000/api
#
#  • REAL / PROD — deploy хийсэн backend (жинхэнэ дата). Энэ рүү чиглүүлбэл
#       admin-аас оруулсан бүхэн PROD DB-д очно (live хэрэглэгчид харна).
#       Railway дээрх live backend:
# VITE_API_URL=https://sparkxp-production.up.railway.app/api
