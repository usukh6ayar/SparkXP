# --- App ---
NODE_ENV=development
PORT=3000

# --- PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=englishxp
# Auto-create schema from entities. Use ONLY in development; use migrations in prod.
DB_SYNCHRONIZE=true
DB_LOGGING=false
# Set to true when using cloud PostgreSQL (Neon, Supabase, etc.)
DB_SSL=false

# --- Redis (cache / queue) ---
# Local: use REDIS_HOST + REDIS_PORT
# Cloud (Upstash): use REDIS_URL instead
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# REDIS_URL=redis://:password@host:port

# --- Auth (JWT) — used in later phases ---
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# --- AI (Anthropic + OpenAI image generation) ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_QUALITY=low

# --- Generated media storage ---
# Production: set Cloudinary credentials so generated word images are persistent.
# If omitted, generated images are saved locally under /uploads/generated (dev only).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=englishxp/generated
CLOUDINARY_WORD_IMAGES_FOLDER=englishxp/words
# Used by local fallback URLs, e.g. https://api.sparkxp.mn
PUBLIC_UPLOAD_BASE_URL=http://localhost:3000

# --- Email (OTP verify + password reset) ---
# Provider is auto-picked at runtime:
#   1. RESEND_API_KEY set        → Resend HTTP API (simplest, no SMTP server)
#   2. else SMTP_HOST set        → SMTP via nodemailer
#   3. else                      → dev STUB (codes are logged, no email sent)
RESEND_API_KEY=
# From address. Resend needs a verified domain in prod (the default is a test sender).
MAIL_FROM=SparkXP <onboarding@resend.dev>
# SMTP fallback (Gmail, Mailgun, etc.) — only used when RESEND_API_KEY is empty
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# --- CORS (production) ---
# Set to your deployed admin Vercel URL e.g. https://sparkxp-admin.vercel.app
ADMIN_ORIGIN=
BASE_URL=http://localhost:3000
REPLICATE_API_TOKEN=
