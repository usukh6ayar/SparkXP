# --- App ---
NODE_ENV=development
PORT=3000

# --- PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=englishxp
# Auto-create schema from entities. Use ONLY in development; use migrations in prod.
DB_SYNCHRONIZE=true
DB_LOGGING=false
# Set to true when using cloud PostgreSQL (Neon, Supabase, etc.)
DB_SSL=false

# --- Redis (cache / queue) ---
# Local: use REDIS_HOST + REDIS_PORT
# Cloud (Upstash): use REDIS_URL instead
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# REDIS_URL=redis://:password@host:port

# --- Auth (JWT) — used in later phases ---
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# --- AI (Anthropic) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- CORS (production) ---
# Set to your deployed admin Vercel URL e.g. https://sparkxp-admin.vercel.app
ADMIN_ORIGIN=
