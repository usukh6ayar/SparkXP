# --- App ---
NODE_ENV=development
PORT=3000

# --- PostgreSQL ---
# Cloud hosts (Railway / Neon / Render) give ONE connection string — set it
# here and the DB_HOST/PORT/... below are ignored. On Railway, reference the
# Postgres plugin: DATABASE_URL=${{Postgres.DATABASE_URL}}
DATABASE_URL=
# Local dev (used only when DATABASE_URL is empty):
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=englishxp
# Auto-create schema from entities. Use ONLY in development.
# In PRODUCTION set this to false and use migrations instead (see below).
DB_SYNCHRONIZE=true
# Production: set DB_SYNCHRONIZE=false and DB_MIGRATIONS_RUN=true so pending
# SQL migrations run automatically on boot. (You can also run them by hand:
# `npm run migration:run`.) Keep false in dev where synchronize is on.
DB_MIGRATIONS_RUN=false
DB_LOGGING=false
# Set to true when using cloud PostgreSQL (Neon, Supabase, etc.)
DB_SSL=false

# --- Redis (cache / queue) ---
# Local: use REDIS_HOST + REDIS_PORT
# Cloud (Upstash / Railway): use REDIS_URL instead.
# On Railway: REDIS_URL=${{Redis.REDIS_URL}}
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# REDIS_URL=redis://:password@host:port

# --- Auth (JWT) — used in later phases ---
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# --- Email (OTP verify + password reset) ---
# Provider is auto-selected: RESEND_API_KEY first, else SMTP_HOST, else a dev
# stub that just logs the code. Set one of these to send real email.
# Option A — Resend (https://resend.com), simplest (HTTP, no SMTP server):
RESEND_API_KEY=
# Option B — any SMTP server (Gmail, Mailgun, SES, etc.):
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# From address for outgoing mail (must be a verified sender on your provider):
MAIL_FROM=SparkXP <onboarding@resend.dev>

# --- AI ---
# Word "AI fill" (text fields) uses Google Gemini. Get a key at
# https://aistudio.google.com/apikey (free tier works for dev):
GEMINI_API_KEY=
# Needs a billing-enabled project key. gemini-2.5-flash = cheap/fast (good
# default); gemini-3.1-pro-preview = higher quality, pricier/slower.
GEMINI_MODEL=gemini-2.5-flash
# AI chat buddy still uses Anthropic (Claude):
ANTHROPIC_API_KEY=sk-ant-...
# Vocabulary image generation goes through Replicate (openai/gpt-image-2).
# Replicate handles OpenAI billing, so you only need a Replicate token.
REPLICATE_API_TOKEN=r8_...
REPLICATE_IMAGE_MODEL=openai/gpt-image-2
# quality: auto | low | medium | high   aspect_ratio: 1:1 | 16:9 | 9:16 | 4:3 | 3:4
REPLICATE_IMAGE_QUALITY=low
REPLICATE_IMAGE_ASPECT_RATIO=1:1
# Optional: override the whole image prompt (placeholders: {word}, {meaning},
# {example_sentence}, {part_of_speech}, {cefr}). Empty = built-in default style.
IMAGE_PROMPT_TEMPLATE=

# --- Pronunciation audio (ElevenLabs TTS) ---
# Without ELEVENLABS_API_KEY the "Audio үүсгэх" feature is disabled (manual
# upload + device TTS still work). Voice/model are optional overrides.
ELEVENLABS_API_KEY=
# Use a PREMADE voice id (free tier). Library/cloned voices need a paid plan.
# Sarah=EXAVITQu4vr4xnSDxMaL, George=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
ELEVENLABS_MODEL=eleven_multilingual_v2
# Cloudinary folder for generated audio (optional)
CLOUDINARY_AUDIO_FOLDER=englishxp/audio

# --- Generated media storage ---
# Production: set Cloudinary credentials so generated word images are persistent.
# If omitted, generated images are saved locally under /uploads/generated (dev only).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=englishxp/generated
CLOUDINARY_WORD_IMAGES_FOLDER=englishxp/words
# Used by local fallback URLs, e.g. https://api.sparkxp.mn
PUBLIC_UPLOAD_BASE_URL=http://localhost:3000

# --- CORS (production) ---
# Set to your deployed admin Vercel URL e.g. https://sparkxp-admin.vercel.app
ADMIN_ORIGIN=
BASE_URL=http://localhost:3000
