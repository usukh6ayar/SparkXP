# --- App ---
NODE_ENV=development
PORT=3000

# --- PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=englishxp
# Auto-create schema from entities. Use ONLY in development; use migrations in prod.
DB_SYNCHRONIZE=true
DB_LOGGING=false

# --- Redis (cache / queue) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Auth (JWT) — used in later phases ---
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# --- AI (Anthropic) ---
ANTHROPIC_API_KEY=sk-ant-...
