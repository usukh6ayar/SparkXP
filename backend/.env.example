# --- App ---
NODE_ENV=development
PORT=3000

# --- PostgreSQL ---
# Cloud hosts (Railway / Neon / Render) give ONE connection string — set it
# here and the DB_HOST/PORT/... below are ignored. On Railway, reference the
# Postgres plugin: DATABASE_URL=${{Postgres.DATABASE_URL}}
DATABASE_URL=
# Local dev (used only when DATABASE_URL is empty):
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=englishxp
# Auto-create schema from entities. Use ONLY in development.
# In PRODUCTION set this to false and use migrations instead (see below).
DB_SYNCHRONIZE=true
# Production: set DB_SYNCHRONIZE=false and DB_MIGRATIONS_RUN=true so pending
# SQL migrations run automatically on boot. (You can also run them by hand:
# `npm run migration:run`.) Keep false in dev where synchronize is on.
DB_MIGRATIONS_RUN=false
DB_LOGGING=false
# Set to true when using cloud PostgreSQL (Neon, Supabase, etc.)
DB_SSL=false

# --- Redis (cache / queue) ---
# Local: use REDIS_HOST + REDIS_PORT
# Cloud (Upstash / Railway): use REDIS_URL instead.
# On Railway: REDIS_URL=${{Redis.REDIS_URL}}
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# REDIS_URL=redis://:password@host:port

# --- Auth (JWT) — used in later phases ---
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# --- Email (OTP verify + password reset) ---
# Provider is auto-selected: RESEND_API_KEY first, else SMTP_HOST, else a dev
# stub that just logs the code. Set one of these to send real email.
# Option A — Resend (https://resend.com), simplest (HTTP, no SMTP server):
RESEND_API_KEY=
# Option B — any SMTP server (Gmail, Mailgun, SES, etc.):
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# From address for outgoing mail (must be a verified sender on your provider):
MAIL_FROM=SparkXP <onboarding@resend.dev>

# --- AI ---
# Word "AI fill" (text fields) uses Google Gemini. Get a key at
# https://aistudio.google.com/apikey (free tier works for dev):
GEMINI_API_KEY=
# Needs a billing-enabled project key. gemini-2.5-flash = cheap/fast (good
# default); gemini-3.1-pro-preview = higher quality, pricier/slower.
GEMINI_MODEL=gemini-2.5-flash
# Max English words per ai-bulk (file) import request (Gemini fills the rest).
AI_BULK_MAX_WORDS=1000
# AI chat buddy still uses Anthropic (Claude):
ANTHROPIC_API_KEY=sk-ant-...
# Vocabulary images = OpenAI directly (gpt-image-2). Needs a billing-enabled
# key. NOTE: GPT Image models require API "Organization Verification" in the
# OpenAI dashboard first, else requests fail. quality=low + 1024x1024 = cheapest.
OPENAI_API_KEY=sk-proj-...
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_QUALITY=low
OPENAI_IMAGE_SIZE=1024x1024
# Retry count for 429 throttle / transient 5xx (exponential backoff).
OPENAI_IMAGE_MAX_RETRIES=5
# Bulk live queue pacing (existing words → "Зураг үүсгэх"):
#   safe = 1 req/sec · normal = 5 req/sec · low = 1 req/10s
IMAGE_RATE_MODE=normal

# --- OpenAI Batch API (cheapest bulk images; async) ---
# For big runs (e.g. 20k words) the OpenAI Batch API is ~50% cheaper than live,
# async (submit → poll → ingest). gpt-image-1-mini = cheapest. Uses OPENAI_API_KEY.
OPENAI_BATCH_IMAGE_MODEL=gpt-image-2
OPENAI_BATCH_IMAGE_SIZE=1024x1024
OPENAI_BATCH_IMAGE_QUALITY=low
# Max words per single batch submit. OpenAI caps enqueued tokens per org
# (gpt-image-2 = 1M ≈ ~800 of our long-prompt images). Raise as your tier grows.
OPENAI_BATCH_MAX_WORDS=800
# Hands-off server queue: words per chunk the cron submits at a time. The cron
# (every minute) submits one chunk, waits for it, ingests, then the next — so big
# runs finish on the server even with the admin's PC off. Keep small: the batch
# OUTPUT file is ~(chunk × 1MB), and ingesting it on a small (~512MB) container
# can OOM. 100 ≈ 30MB output. Raise only if the container has more memory.
IMAGE_BATCH_CHUNK=100
# Optional: override the whole image prompt (placeholders: {word}, {meaning},
# {example_sentence}, {part_of_speech}, {cefr}). Empty = built-in default style.
IMAGE_PROMPT_TEMPLATE=

# --- Pronunciation audio (ElevenLabs TTS) ---
# Without ELEVENLABS_API_KEY the "Audio үүсгэх" feature is disabled (manual
# upload + device TTS still work). Voice/model are optional overrides.
ELEVENLABS_API_KEY=
# Use a PREMADE voice id (free tier). Library/cloned voices need a paid plan.
# Sarah=EXAVITQu4vr4xnSDxMaL, George=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
ELEVENLABS_MODEL=eleven_multilingual_v2
# Cloudinary folder for generated audio (optional)
CLOUDINARY_AUDIO_FOLDER=englishxp/audio

# --- AI Buddy (voice speaking companion) ---
# Provider selection is config-driven (adapters live in ai-gateway/providers).
# Defaults match the current vendors; STT uses ElevenLabs Scribe.
STT_PROVIDER=elevenlabs
LLM_PROVIDER=anthropic
TTS_PROVIDER=elevenlabs
# Privacy: raw uploaded audio is NOT stored by default (in-memory only).
AI_BUDDY_LOG_RAW_AUDIO=false
AI_BUDDY_AUDIO_RETENTION_DAYS=0
# NOTE: reply length, CEFR default, STT confidence threshold, daily voice-turn
# cap live in the Redis limits blob (ai:limits:default) — admin-tunable at
# runtime via PATCH /ai/limits, not env.

# --- Generated media storage ---
# Production: set Cloudinary credentials so generated word images are persistent.
# If omitted, generated images are saved locally under /uploads/generated (dev only).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=englishxp/generated
CLOUDINARY_WORD_IMAGES_FOLDER=englishxp/words
# Used by local fallback URLs, e.g. https://api.sparkxp.mn
PUBLIC_UPLOAD_BASE_URL=http://localhost:3000

# --- CORS (production) ---
# Set to your deployed admin Vercel URL e.g. https://sparkxp-admin.vercel.app
ADMIN_ORIGIN=
BASE_URL=http://localhost:3000
