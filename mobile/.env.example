# === Backend API base URL (EXPO_PUBLIC_ → read in the app at runtime) ===
#
# ⚠️ Real phone + your Mac must be on the SAME network.
#    If the IP changes (new router/network), update it here and restart Expo (-c).
#    A wrong IP makes the phone hang / feel "very slow" (request timeout).
#
#  • LAN (ethernet/cable):  ifconfig | grep "inet " | grep -v 127.0.0.1
#  • WiFi:                  ipconfig getifaddr en0
#  • Simulator / web only:  localhost works.

# LOCAL / TEST backend (Mac + local Postgres = test data). Phone → Mac's IP:
EXPO_PUBLIC_API_URL=http://192.168.1.10:3000/api   # ← put YOUR Mac's IP here
# EXPO_PUBLIC_API_URL=http://localhost:3000/api      # simulator / web only
#
# REAL / PROD backend (deployed = real data). Each backend has its own DB —
# local & prod data are NOT shared. Point here once deployed:
# EXPO_PUBLIC_API_URL=https://api.sparkxp.mn/api
